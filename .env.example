# Frontend Environment Variables
# Copy from your Google Cloud Console OAuth 2.0 credentials

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API URL
VITE_API_URL=http://localhost:3000/api

# Environment
VITE_ENV=development

# -----------------------------------------------------------------------------
# NOTE: The backend also requires a large set of environment variables.
#       See backend/.env.example for the complete list and copy it to
#       backend/.env before running the server or deploying to Render.
# -----------------------------------------------------------------------------
